#!/bin/bash
path=$(osascript -e 'tell application "Finder" to if (count of Finder windows) > 0 then get POSIX path of (target of front Finder window as alias)')
target="${path:-$HOME}"

# macOS mktemp 不支持后缀，用 -t 生成基础名再重命名加 .zsh 后缀
tmpbase=$(mktemp /tmp/ghostty_init_XXXXXX)
tmpscript="${tmpbase}.zsh"
mv "$tmpbase" "$tmpscript"
chmod 700 "$tmpscript"

quoted_target=$(printf '%q' "$target")
quoted_tmpscript=$(printf '%q' "$tmpscript")

cat > "$tmpscript" << EOF
#!/bin/zsh
cd ${quoted_target}
printf '\033[1;34m%s\033[0m\n' ${quoted_target}
rm -f ${quoted_tmpscript}
exec /bin/zsh -i
EOF

# 用 -na 强制新实例，确保 Ghostty 已运行时 --args 也能生效
open -na "Ghostty" --args -e "$tmpscript" &